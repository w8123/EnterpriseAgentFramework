## 示例：创建 AI 平台所需的 Secret（请勿将真实值提交到 Git）
## 使用方法: kubectl apply -f secrets.yml
apiVersion: v1
kind: Secret
metadata:
  name: ai-secrets
type: Opaque
stringData:
  dashscope-api-key: "sk-your-dashscope-key"
  jishi-api-key: "app-your-jishi-key"
  mysql-url: "jdbc:mysql://mysql:3306/ai_text_service?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai"
  mysql-user: "root"
  mysql-password: "your-mysql-password"
