# ============================================
# Enterprise Agent Framework - Unified .gitignore
# ============================================

# ---- Compiled / Build ----
*.class
*.log
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
*.pid
target/
tmp/
.codex-logs/
logs/

# ---- JVM crash logs ----
hs_err_pid*
replay_pid*

# ---- IDE ----
.idea/
*.iml
.vscode/
.worktrees/
.classpath
.project
.settings/
.factorypath
.springBeans

# Shared IntelliJ run configs for the five ReachAI services are intentionally tracked.
# Keep .run/ out of this ignore list.

# ---- AI / Local Assistant Tooling ----
.claude/
.mimocode/
.playwright-cli/
.superpowers/
.cursor/*
!.cursor/
!.cursor/rules/
!.cursor/rules/**
.cursor/playwright-output/
.cursor/mcp.json
.cursor/dbhub-ai-mysql.toml

# ---- Frontend (ai-admin-front) ----
ai-admin-front/node_modules/
ai-admin-front/dist/
ai-admin-front/.vite/

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Environment / Secrets ----
.env
.env.local
.env.*.local
**/application-local.yml
**/application-secret.yml
ai-admin-front/nul

OtherOutstandingProjects/
